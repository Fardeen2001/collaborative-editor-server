# Server
PORT=8000
HOST=0.0.0.0
NODE_ENV=development
PUBLIC_URL=
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=collaborative_editor

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# WebSocket
WS_PATH=/ws
MAX_MESSAGE_SIZE=262144
WS_RATE_LIMIT=60
WS_RECONNECT_CHECK_MS=10000
WS_RECONNECT_DELAY_MS=2000
WS_TOKEN_PARAM=token
WS_DOCUMENT_ID_PARAM=documentId

# Sync
MAX_DOC_UPDATES=50000
SNAPSHOT_INTERVAL=200

# API rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
JSON_BODY_LIMIT=1mb
API_PREFIX=/api

# Yjs
YJS_FIELD_NAME=prosemirror
YJS_MESSAGE_SYNC=0
YJS_MESSAGE_AWARENESS=1

# Validation limits
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
NAME_MAX_LENGTH=80
TITLE_MAX_LENGTH=200
SNAPSHOT_LABEL_MAX_LENGTH=120
AI_TEXT_MAX_LENGTH=8000
AI_INSTRUCTION_MAX_LENGTH=200

# Defaults
DEFAULT_SNAPSHOT_LABEL=Manual snapshot
DEFAULT_AUTO_SNAPSHOT_LABEL=Auto snapshot
DEFAULT_FALLBACK_SNAPSHOT_LABEL=Snapshot
DEFAULT_AI_INSTRUCTION=Improve clarity and grammar while preserving meaning.

# Storage keys (exposed to client via /api/config)
IDB_DOC_PREFIX=doc-
OUTBOX_DB_NAME=collab-editor-outbox
OUTBOX_STORE_NAME=outbox
OUTBOX_DB_VERSION=1

# AI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_TEMPERATURE=0.3
OPENAI_SYSTEM_PROMPT=You are a writing assistant. Return only the improved text, no commentary.
